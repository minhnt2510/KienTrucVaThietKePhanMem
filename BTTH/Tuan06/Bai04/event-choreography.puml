@startuml
title Food Ordering Workflow - Event Choreography

actor User
participant "Order Service" as Order
participant "Payment Service" as Payment
participant "Inventory Service" as Inventory
participant "Delivery Service" as Delivery

User -> Order: Place Order
Order -> Order: Create Order (PENDING)
Order -> Payment: "OrderCreated" Event

Payment -> Payment: Process Payment
alt Payment Success
    Payment -> Inventory: "PaymentSucceeded" Event
    Inventory -> Inventory: Reserve Items
    alt Inventory Available
        Inventory -> Delivery: "InventoryReserved" Event
        Delivery -> Delivery: Schedule Delivery
        Delivery -> Order: "DeliveryScheduled" Event
        Order -> Order: Update Order (COMPLETED)
        Order -> User: Order Confirmed
    else Inventory Unavailable
        Inventory -> Payment: "InventoryFailed" Event
        Payment -> Payment: Refund Payment
        Payment -> Order: "PaymentRefunded" Event
        Order -> Order: Update Order (CANCELLED)
        Order -> User: Order Failed
    end
else Payment Failed
    Payment -> Order: "PaymentFailed" Event
    Order -> Order: Update Order (CANCELLED)
    Order -> User: Order Failed
end

@enduml
